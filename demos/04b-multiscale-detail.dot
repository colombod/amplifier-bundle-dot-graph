// Demo 4b: Multi-Scale Navigation — DETAIL (Gateway & Auth subsystem zoom-in)
// Demonstrates: DOT as multi-scale navigation (zoom-in view)
// Zooms into cluster_gateway from 04a-multiscale-overview.dot

digraph multiscale_detail {
    rankdir=LR
    compound=true
    fontname="Helvetica"
    fontsize=14
    label=<<B>CloudSaaS Platform — Gateway &amp; Auth Detail</B><BR/>
           <FONT POINT-SIZE="11">Zoom-in: cluster_gateway from overview · Full internal structure</FONT>>
    labelloc=t
    labeljust=c
    pad=0.6
    nodesep=0.5
    ranksep=0.75
    bgcolor="white"

    node [fontname="Helvetica", fontsize=10, style=filled]
    edge [fontname="Helvetica", fontsize=9, color="#555555"]

    // =========================================================================
    // External entrypoints (boundary — same nodes as overview)
    // =========================================================================

    subgraph cluster_external {
        label=<<B>External (from overview)</B>>
        style="rounded,dashed"
        color="#607D8B"
        bgcolor="#ECEFF1"

        web_client  [label=<<B>Web Client</B>>, shape=box, style="rounded,filled", fillcolor="#CFD8DC"]
        mobile_app  [label=<<B>Mobile App</B>>, shape=box, style="rounded,filled", fillcolor="#CFD8DC"]
        partner_api [label=<<B>Partner APIs</B>>, shape=box, style="rounded,filled", fillcolor="#CFD8DC"]
    }

    // =========================================================================
    // TLS termination
    // =========================================================================

    subgraph cluster_tls {
        label=<<B>TLS Termination</B>>
        style=rounded
        color="#78909C"
        bgcolor="#F5F5F5"

        tls_terminator [label=<<B>TLS Terminator</B><BR/>
                         <FONT POINT-SIZE="9">nginx · Let's Encrypt<BR/>
                         TLSv1.3 only</FONT>>,
                         shape=box, style="rounded,filled", fillcolor="#ECEFF1"]
    }

    // =========================================================================
    // Rate limiting & WAF
    // =========================================================================

    subgraph cluster_ingress {
        label=<<B>Ingress Controls</B>>
        style=rounded
        color="#37474F"
        bgcolor="#ECEFF1"

        rate_limiter [label=<<B>Rate Limiter</B><BR/>
                      <FONT POINT-SIZE="9">Token bucket algorithm<BR/>
                      Per-tenant limits<BR/>
                      Redis-backed counters</FONT>>,
                      shape=box, style="rounded,filled", fillcolor="#CFD8DC"]

        waf [label=<<B>WAF</B><BR/>
             <FONT POINT-SIZE="9">ModSecurity rules<BR/>
             OWASP CRS<BR/>
             Block / log / allow</FONT>>,
             shape=diamond, fillcolor="#FFF9C4", color="#F9A825"]
    }

    // =========================================================================
    // Auth pipeline
    // =========================================================================

    subgraph cluster_auth {
        label=<<B>Authentication Pipeline</B>>
        style=rounded
        color="#1565C0"
        penwidth=2
        bgcolor="#E3F2FD"

        token_extractor [label=<<B>Token Extractor</B><BR/>
                          <FONT POINT-SIZE="9">Parse Authorization header<BR/>
                          Bearer / API-key / mTLS cert</FONT>>,
                          shape=box, style="rounded,filled", fillcolor="#BBDEFB"]

        token_type_gate [label="Token Type?", shape=diamond, fillcolor="#FFF9C4", color="#F9A825"]

        jwt_validator [label=<<B>JWT Validator</B><BR/>
                        <FONT POINT-SIZE="9">Verify signature · expiry<BR/>
                        Claims extraction<BR/>
                        JWKS endpoint (cached)</FONT>>,
                        shape=box, style="rounded,filled", fillcolor="#BBDEFB"]

        apikey_validator [label=<<B>API-Key Validator</B><BR/>
                           <FONT POINT-SIZE="9">Hash-compare against DB<BR/>
                           Scope check<BR/>
                           Rate quota lookup</FONT>>,
                           shape=box, style="rounded,filled", fillcolor="#BBDEFB"]

        mtls_validator [label=<<B>mTLS Cert Validator</B><BR/>
                         <FONT POINT-SIZE="9">Partner API path only<BR/>
                         Client cert pinning</FONT>>,
                         shape=box, style="rounded,filled", fillcolor="#BBDEFB"]

        auth_cache [label=<<B>Auth Cache</B><BR/>
                     <FONT POINT-SIZE="9">Redis · TTL: 5 min<BR/>
                     Cache validated tokens</FONT>>,
                     shape=cylinder, fillcolor="#B3E5FC"]

        jwks_store [label=<<B>JWKS Store</B><BR/>
                     <FONT POINT-SIZE="9">Cached public keys<BR/>
                     Refresh: every 1h</FONT>>,
                     shape=cylinder, fillcolor="#B3E5FC"]
    }

    // =========================================================================
    // Authorization & routing
    // =========================================================================

    subgraph cluster_authz {
        label=<<B>Authorization &amp; Routing</B>>
        style=rounded
        color="#2E7D32"
        penwidth=2
        bgcolor="#E8F5E9"

        authz_engine [label=<<B>Authz Engine</B><BR/>
                       <FONT POINT-SIZE="9">OPA (Open Policy Agent)<BR/>
                       Tenant isolation check<BR/>
                       RBAC policy evaluation</FONT>>,
                       shape=box, style="rounded,filled", fillcolor="#C8E6C9"]

        route_table [label=<<B>Route Table</B><BR/>
                      <FONT POINT-SIZE="9">Path → service mapping<BR/>
                      Version routing (A/B)<BR/>
                      Feature-flag overrides</FONT>>,
                      shape=box, style="rounded,filled", fillcolor="#C8E6C9"]

        request_enricher [label=<<B>Request Enricher</B><BR/>
                           <FONT POINT-SIZE="9">Inject headers:<BR/>
                           X-Tenant-ID · X-User-ID<BR/>
                           X-Scopes · X-Request-ID</FONT>>,
                           shape=box, style="rounded,filled", fillcolor="#C8E6C9"]

        policy_store [label=<<B>Policy Store</B><BR/>
                       <FONT POINT-SIZE="9">OPA bundles in S3<BR/>
                       Hot-reload every 30s</FONT>>,
                       shape=cylinder, fillcolor="#A5D6A7"]
    }

    // =========================================================================
    // Downstream services (boundary — same as overview)
    // =========================================================================

    subgraph cluster_downstream {
        label=<<B>Downstream Services (from overview)</B>>
        style="rounded,dashed"
        color="#607D8B"
        bgcolor="#ECEFF1"

        user_svc    [label=<<B>User Service</B>>,    shape=box, style="rounded,filled", fillcolor="#CFD8DC"]
        catalog_svc [label=<<B>Catalog Service</B>>, shape=box, style="rounded,filled", fillcolor="#CFD8DC"]
        order_svc   [label=<<B>Order Service</B>>,   shape=box, style="rounded,filled", fillcolor="#CFD8DC"]
    }

    // =========================================================================
    // Error paths
    // =========================================================================

    auth_denied [label=<<B>401 / 403</B><BR/><FONT POINT-SIZE="9">Return error response</FONT>>, shape=box, style="rounded,filled", fillcolor="#FFCDD2", color="#C62828"]

    rate_limited [label=<<B>429 Too Many Requests</B><BR/><FONT POINT-SIZE="9">Retry-After header</FONT>>, shape=box, style="rounded,filled", fillcolor="#FFCDD2", color="#C62828"]

    // =========================================================================
    // Flow
    // =========================================================================

    web_client  -> tls_terminator [label="TLSv1.3", penwidth=2]
    mobile_app  -> tls_terminator [label="TLSv1.3", penwidth=2]
    partner_api -> tls_terminator [label="mTLS", style=dashed]

    tls_terminator -> waf         [label="plaintext"]
    waf            -> rate_limiter [label="allowed"]
    waf            -> auth_denied  [label="blocked", color="#C62828", style=dashed]
    rate_limiter   -> token_extractor [label="within limit"]
    rate_limiter   -> rate_limited    [label="exceeded", color="#C62828", style=dashed]

    token_extractor -> token_type_gate
    token_extractor -> auth_cache  [label="cache check", style=dashed]
    auth_cache      -> authz_engine [label="hit: skip validate", style=dashed, color="#90CAF9"]

    token_type_gate -> jwt_validator    [label="JWT"]
    token_type_gate -> apikey_validator [label="API-Key"]
    token_type_gate -> mtls_validator   [label="mTLS cert"]

    jwt_validator    -> jwks_store   [label="verify sig", style=dashed]
    jwt_validator    -> authz_engine [label="valid claims"]
    jwt_validator    -> auth_denied  [label="invalid/expired", color="#C62828", style=dashed]
    apikey_validator -> authz_engine [label="valid key"]
    apikey_validator -> auth_denied  [label="invalid key",  color="#C62828", style=dashed]
    mtls_validator   -> authz_engine [label="cert valid"]
    mtls_validator   -> auth_denied  [label="cert rejected", color="#C62828", style=dashed]

    authz_engine -> policy_store    [label="eval policy", style=dashed]
    authz_engine -> route_table     [label="authorized"]
    authz_engine -> auth_denied     [label="denied",    color="#C62828", style=dashed]

    route_table      -> request_enricher [label="route selected"]
    request_enricher -> user_svc    [label="if /users/*"]
    request_enricher -> catalog_svc [label="if /catalog/*"]
    request_enricher -> order_svc   [label="if /orders/*"]

    // Write validated token to cache
    jwt_validator    -> auth_cache [label="cache", style=dashed, color="#A5D6A7", constraint=false]
    apikey_validator -> auth_cache [label="cache", style=dashed, color="#A5D6A7", constraint=false]

    // =========================================================================
    // Legend
    // =========================================================================

    subgraph cluster_legend {
        label=<<B>Legend</B>>
        style=rounded
        color="#9E9E9E"
        bgcolor="#FAFAFA"
        fontsize=10
        node [fontsize=9, height=0.3]

        l_svc    [label="Service",         shape=box, style="rounded,filled", fillcolor="#BBDEFB", width=1.7]
        l_gate   [label="Decision gate",   shape=diamond, fillcolor="#FFF9C4", color="#F9A825", width=1.7]
        l_store  [label="Data store",      shape=cylinder, fillcolor="#B3E5FC", width=1.7]
        l_bound  [label="Boundary (from overview)", shape=box, style="rounded,filled", fillcolor="#CFD8DC", width=2.0]
        l_error  [label="Error response",  shape=box, style="rounded,filled", fillcolor="#FFCDD2", color="#C62828", width=1.7]

        l_svc -> l_gate -> l_store -> l_bound -> l_error [style=invis]
    }
}
