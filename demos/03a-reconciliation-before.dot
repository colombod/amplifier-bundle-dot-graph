// Demo 3a: Reconciliation — BEFORE (naive understanding with gaps)
// Demonstrates: DOT as reconciliation forcing function
// Scenario: Developer's mental model of a cloud order-processing service

digraph reconciliation_before {
    rankdir=LR
    compound=true
    fontname="Helvetica"
    fontsize=14
    label=<<B>Order Processing System — BEFORE Reconciliation</B><BR/>
           <FONT POINT-SIZE="11" COLOR="#B71C1C">Developer's mental model: gaps, assumptions, and dead code hidden</FONT>>
    labelloc=t
    labeljust=c
    pad=0.6
    nodesep=0.5
    ranksep=0.7
    bgcolor="white"

    node [fontname="Helvetica", fontsize=10, style=filled]
    edge [fontname="Helvetica", fontsize=9, color="#555555"]

    // =========================================================================
    // Ingestion layer
    // =========================================================================

    subgraph cluster_ingestion {
        label=<<B>Ingestion</B>>
        style=rounded
        color="#1565C0"
        penwidth=2
        bgcolor="#E3F2FD"

        api_gateway [label=<<B>API Gateway</B><BR/><FONT POINT-SIZE="9">Routes incoming orders</FONT>>,
                     shape=box, style="rounded,filled", fillcolor="#BBDEFB"]
        order_api   [label=<<B>Order API</B><BR/><FONT POINT-SIZE="9">POST /orders endpoint</FONT>>,
                     shape=box, style="rounded,filled", fillcolor="#BBDEFB"]
        auth_svc    [label=<<B>Auth Service</B><BR/><FONT POINT-SIZE="9">(believed: validates JWT)</FONT>>,
                     shape=box, style="rounded,filled", fillcolor="#BBDEFB"]
    }

    // =========================================================================
    // Processing layer
    // =========================================================================

    subgraph cluster_processing {
        label=<<B>Processing</B>>
        style=rounded
        color="#2E7D32"
        penwidth=2
        bgcolor="#E8F5E9"

        order_validator [label=<<B>Order Validator</B><BR/><FONT POINT-SIZE="9">Validates schema</FONT>>,
                         shape=box, style="rounded,filled", fillcolor="#C8E6C9"]
        inventory_svc   [label=<<B>Inventory Service</B><BR/><FONT POINT-SIZE="9">(believed: checks stock)</FONT>>,
                         shape=box, style="rounded,filled", fillcolor="#C8E6C9"]
        pricing_engine  [label=<<B>Pricing Engine</B><BR/><FONT POINT-SIZE="9">(believed: applies discounts)</FONT>>,
                         shape=box, style="rounded,filled", fillcolor="#C8E6C9"]
        payment_svc     [label=<<B>Payment Service</B><BR/><FONT POINT-SIZE="9">(believed: retries 3x)</FONT>>,
                         shape=box, style="rounded,filled", fillcolor="#C8E6C9"]
        retry_logic     [label=<<B>Retry Logic</B><BR/><FONT POINT-SIZE="9">(believed: 3 attempts)</FONT>>,
                         shape=box, style="rounded,filled", fillcolor="#FFF9C4"]
    }

    // =========================================================================
    // Fulfilment layer
    // =========================================================================

    subgraph cluster_fulfilment {
        label=<<B>Fulfilment</B>>
        style=rounded
        color="#E65100"
        penwidth=2
        bgcolor="#FFF3E0"

        fulfilment_svc  [label=<<B>Fulfilment Service</B><BR/><FONT POINT-SIZE="9">Creates shipment record</FONT>>,
                         shape=box, style="rounded,filled", fillcolor="#FFE0B2"]
        shipping_api    [label=<<B>Shipping API</B><BR/><FONT POINT-SIZE="9">(external)</FONT>>,
                         shape=box, style="rounded,filled", fillcolor="#FFCCBC"]
        notification_svc [label=<<B>Notification Service</B><BR/><FONT POINT-SIZE="9">(believed: sends email + SMS)</FONT>>,
                          shape=box, style="rounded,filled", fillcolor="#FFE0B2"]
    }

    // =========================================================================
    // Data stores
    // =========================================================================

    subgraph cluster_stores {
        label=<<B>Data Stores</B>>
        style=rounded
        color="#6A1B9A"
        penwidth=2
        bgcolor="#F3E5F5"

        order_db    [label=<<B>Orders DB</B><BR/><FONT POINT-SIZE="9">PostgreSQL</FONT>>,
                     shape=cylinder, fillcolor="#E1BEE7"]
        cache       [label=<<B>Cache</B><BR/><FONT POINT-SIZE="9">(believed: Redis, warming requests)</FONT>>,
                     shape=cylinder, fillcolor="#E1BEE7"]
        event_queue [label=<<B>Event Queue</B><BR/><FONT POINT-SIZE="9">(believed: Kafka, async)</FONT>>,
                     shape=cylinder, fillcolor="#E1BEE7"]
    }

    // =========================================================================
    // Believed-but-unused module (dead code)
    // =========================================================================

    subgraph cluster_analytics {
        label=<<B>Analytics</B>>
        style=rounded
        color="#9E9E9E"
        penwidth=1
        bgcolor="#FAFAFA"

        analytics_svc [label=<<B>Analytics Service</B><BR/><FONT POINT-SIZE="9">(believed: receives order events)</FONT>>,
                       shape=box, style="rounded,filled", fillcolor="#F5F5F5"]
        reporting_db  [label=<<B>Reporting DB</B><BR/><FONT POINT-SIZE="9">(believed: updated by analytics)</FONT>>,
                       shape=cylinder, fillcolor="#EEEEEE"]
    }

    // =========================================================================
    // Believed flow edges
    // =========================================================================

    api_gateway   -> order_api       [label="route"]
    api_gateway   -> auth_svc        [label="validate token"]
    auth_svc      -> order_api       [label="authorized"]
    order_api     -> order_validator [label="validate"]
    order_api     -> cache           [label="warm/check"]
    order_validator -> inventory_svc [label="check stock"]
    inventory_svc   -> pricing_engine [label="priced"]
    pricing_engine  -> payment_svc   [label="charge"]
    payment_svc     -> retry_logic   [label="on failure"]
    retry_logic     -> payment_svc   [label="retry attempt", style=dashed]
    payment_svc     -> order_db      [label="record success"]
    payment_svc     -> event_queue   [label="emit event (async)", style=dashed]
    event_queue     -> fulfilment_svc [label="trigger"]
    fulfilment_svc  -> shipping_api  [label="create shipment"]
    fulfilment_svc  -> notification_svc [label="notify customer"]
    event_queue     -> analytics_svc [label="order.completed"]
    analytics_svc   -> reporting_db  [label="write"]

    // =========================================================================
    // Legend
    // =========================================================================

    subgraph cluster_legend {
        label=<<B>Legend</B>>
        style=rounded
        color="#9E9E9E"
        bgcolor="#FAFAFA"
        fontsize=10
        node [fontsize=9, height=0.3]

        l_svc   [label="Service / component", shape=box, style="rounded,filled", fillcolor="#C8E6C9", width=1.9]
        l_store [label="Data store", shape=cylinder, fillcolor="#E1BEE7", width=1.9]
        l_async [label="Async / believed path", shape=plaintext, fillcolor="white", width=1.9]
        l_note  [label="\"(believed: ...)\" = unverified assumption", shape=note, fillcolor="#FFF9C4", width=2.2]

        l_svc -> l_store -> l_async -> l_note [style=invis]
    }
}
