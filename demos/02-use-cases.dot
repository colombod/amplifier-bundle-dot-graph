// Demo 2: The 7 Use Cases of DOT in the Amplifier Ecosystem
// Demonstrates: DOT as dense representation

digraph dot_use_cases {
    rankdir=TB
    compound=true
    fontname="Helvetica"
    fontsize=14
    label=<<B>DOT in the Amplifier Ecosystem — 7 Primary Use Cases</B><BR/>
           <FONT POINT-SIZE="11">How graph representation creates value at every level</FONT>>
    labelloc=t
    labeljust=c
    pad=0.7
    nodesep=0.55
    ranksep=0.8
    bgcolor="white"

    node [fontname="Helvetica", fontsize=10, style=filled]
    edge [fontname="Helvetica", fontsize=9, color="#555555"]

    // =========================================================================
    // Central hub: DOT as medium
    // =========================================================================

    dot_medium [label=<<B>DOT Language</B><BR/>
                <FONT POINT-SIZE="9">Graph description as text<BR/>
                Parseable · Diffable · Versionable<BR/>
                Renders as image, data, or text</FONT>>,
                shape=circle, width=1.8, height=1.8,
                fillcolor="#1565C0", fontcolor="white", color="#0D47A1",
                penwidth=2]

    // =========================================================================
    // The 7 Use Cases (arranged radially)
    // =========================================================================

    // UC1: Dense representation
    uc1 [label=<<B>1. Dense Representation</B><BR/>
         <FONT POINT-SIZE="9">Encode complex structures in<BR/>
         compact, parseable text.<BR/>
         Full system in &lt;300 lines.</FONT>>,
         shape=box, style="rounded,filled",
         fillcolor="#E3F2FD", color="#1565C0", penwidth=2]

    uc1_ex [label=<<FONT POINT-SIZE="9">Architecture diagrams<BR/>
            Dependency graphs<BR/>Bundle composition maps</FONT>>,
            shape=note, fillcolor="#BBDEFB", color="#1976D2"]

    // UC2: Reconciliation forcing function
    uc2 [label=<<B>2. Reconciliation Forcing Function</B><BR/>
         <FONT POINT-SIZE="9">Drawing makes structural claims.<BR/>
         Claims can be verified.<BR/>
         Gaps reveal bugs.</FONT>>,
         shape=box, style="rounded,filled",
         fillcolor="#FCE4EC", color="#AD1457", penwidth=2]

    uc2_ex [label=<<FONT POINT-SIZE="9">Before/after investigation<BR/>
            Dead code detection<BR/>Missing path discovery</FONT>>,
            shape=note, fillcolor="#F8BBD9", color="#C2185B"]

    // UC3: Multi-scale navigation
    uc3 [label=<<B>3. Multi-Scale Navigation</B><BR/>
         <FONT POINT-SIZE="9">Same graph renders at detail<BR/>
         or overview level.<BR/>
         Zoom in/out with subgraphs.</FONT>>,
         shape=box, style="rounded,filled",
         fillcolor="#E8F5E9", color="#2E7D32", penwidth=2]

    uc3_ex [label=<<FONT POINT-SIZE="9">Overview + detail pairs<BR/>
            Cluster collapse/expand<BR/>Progressive disclosure</FONT>>,
            shape=note, fillcolor="#C8E6C9", color="#388E3C"]

    // UC4: Analysis substrate
    uc4 [label=<<B>4. Analysis Substrate</B><BR/>
         <FONT POINT-SIZE="9">Machines query, transform,<BR/>
         and reason over graph structure.<BR/>
         NetworkX · dot_analyze</FONT>>,
         shape=box, style="rounded,filled",
         fillcolor="#F3E5F5", color="#6A1B9A", penwidth=2]

    uc4_ex [label=<<FONT POINT-SIZE="9">Cycle detection<BR/>
            Centrality · critical paths<BR/>Reachability queries</FONT>>,
            shape=note, fillcolor="#E1BEE7", color="#7B1FA2"]

    // UC5: Multi-modal bridge
    uc5 [label=<<B>5. Multi-Modal Bridge</B><BR/>
         <FONT POINT-SIZE="9">Same source renders as:<BR/>
         PNG/SVG · JSON · text<BR/>
         Works across all tools.</FONT>>,
         shape=box, style="rounded,filled",
         fillcolor="#FFF3E0", color="#E65100", penwidth=2]

    uc5_ex [label=<<FONT POINT-SIZE="9">Slack image attachments<BR/>
            VS Code previews<BR/>API-consumable graph data</FONT>>,
            shape=note, fillcolor="#FFE0B2", color="#F57C00"]

    // UC6: Workflow visualization
    uc6 [label=<<B>6. Workflow Visualization</B><BR/>
         <FONT POINT-SIZE="9">Maps processes, pipelines,<BR/>
         state machines clearly.<BR/>
         Recipes as graphs.</FONT>>,
         shape=box, style="rounded,filled",
         fillcolor="#E0F2F1", color="#00695C", penwidth=2]

    uc6_ex [label=<<FONT POINT-SIZE="9">Recipe step diagrams<BR/>
            CI/CD pipeline maps<BR/>Agent workflow graphs</FONT>>,
            shape=note, fillcolor="#B2DFDB", color="#00796B"]

    // UC7: Investigation artifact
    uc7 [label=<<B>7. Investigation Artifact</B><BR/>
         <FONT POINT-SIZE="9">Captures findings in persistent,<BR/>
         shareable, diffable form.<BR/>
         Git-tracked evidence.</FONT>>,
         shape=box, style="rounded,filled",
         fillcolor="#FFF8E1", color="#F57F17", penwidth=2]

    uc7_ex [label=<<FONT POINT-SIZE="9">Parallax session graphs<BR/>
            Incident post-mortems<BR/>Architecture decisions</FONT>>,
            shape=note, fillcolor="#FFF9C4", color="#F9A825"]

    // =========================================================================
    // Hub connections
    // =========================================================================

    dot_medium -> uc1 [color="#1565C0", penwidth=2, label="compact\nencoding"]
    dot_medium -> uc2 [color="#AD1457", penwidth=2, label="forces\ncompleteness"]
    dot_medium -> uc3 [color="#2E7D32", penwidth=2, label="subgraph\nhierarchy"]
    dot_medium -> uc4 [color="#6A1B9A", penwidth=2, label="parseable\nstructure"]
    dot_medium -> uc5 [color="#E65100", penwidth=2, label="multi-format\nrender"]
    dot_medium -> uc6 [color="#00695C", penwidth=2, label="DAG\npattern"]
    dot_medium -> uc7 [color="#F57F17", penwidth=2, label="text +\nimage"]

    uc1 -> uc1_ex [style=dashed, color="#90CAF9", arrowhead=none]
    uc2 -> uc2_ex [style=dashed, color="#F48FB1", arrowhead=none]
    uc3 -> uc3_ex [style=dashed, color="#A5D6A7", arrowhead=none]
    uc4 -> uc4_ex [style=dashed, color="#CE93D8", arrowhead=none]
    uc5 -> uc5_ex [style=dashed, color="#FFCC80", arrowhead=none]
    uc6 -> uc6_ex [style=dashed, color="#80CBC4", arrowhead=none]
    uc7 -> uc7_ex [style=dashed, color="#FFF176", arrowhead=none]

    // =========================================================================
    // Cross-use-case relationships
    // =========================================================================

    uc1 -> uc3 [label="enables", style=dashed, color="#888888", constraint=false]
    uc2 -> uc7 [label="produces", style=dashed, color="#888888", constraint=false]
    uc3 -> uc4 [label="feeds", style=dashed, color="#888888", constraint=false]
    uc6 -> uc2 [label="exposes\ngaps", style=dashed, color="#888888", constraint=false]
    uc4 -> uc2 [label="surfaces\npatterns", style=dashed, color="#888888", constraint=false]

    // =========================================================================
    // Amplifier integration note
    // =========================================================================

    subgraph cluster_bundle_note {
        label=<<B>dot-graph bundle provides</B>>
        style=rounded
        color="#607D8B"
        bgcolor="#FAFAFA"

        bundle_note [label=<<B>dot-author</B> agent → UC 1, 3, 6<BR/>
                     <B>diagram-reviewer</B> → UC 2, 7<BR/>
                     <B>dot_analyze</B> tool → UC 4<BR/>
                     <B>dot_render</B> tool → UC 5>,
                     shape=box, style="rounded,filled",
                     fillcolor="#ECEFF1", color="#607D8B", fontsize=9]
    }

    dot_medium -> bundle_note [label="implemented by", style=dotted, color="#90A4AE", lhead=cluster_bundle_note]

    // =========================================================================
    // Legend
    // =========================================================================

    subgraph cluster_legend {
        label=<<B>Legend</B>>
        style=rounded
        color="#9E9E9E"
        bgcolor="#FAFAFA"
        fontsize=10
        node [fontsize=9, height=0.3]

        l_hub  [label="Core medium", shape=circle, fillcolor="#1565C0", fontcolor="white", width=0.7]
        l_uc   [label="Use case", shape=box, style="rounded,filled", fillcolor="#E3F2FD", color="#1565C0", width=1.5]
        l_ex   [label="Examples", shape=note, fillcolor="#BBDEFB", color="#1976D2", width=1.5]
        l_rel  [label="Cross-case\nrelationship", shape=plaintext, fillcolor="white", width=1.5]

        l_hub -> l_uc -> l_ex -> l_rel [style=invis]
    }
}
