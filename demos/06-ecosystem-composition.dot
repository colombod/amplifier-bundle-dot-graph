// Demo 6: Ecosystem Composition — how dot-graph composes into the Amplifier ecosystem
// Demonstrates: the bundle's composition model, context sink pattern, capability propagation

digraph ecosystem_composition {
    rankdir=TB
    compound=true
    fontname="Helvetica"
    fontsize=14
    label=<<B>dot-graph Bundle — Ecosystem Composition Model</B><BR/>
           <FONT POINT-SIZE="11">How the behavior propagates capabilities · Context sink pattern · Bundle hierarchy</FONT>>
    labelloc=t
    labeljust=c
    pad=0.7
    nodesep=0.55
    ranksep=0.85
    bgcolor="white"

    node [fontname="Helvetica", fontsize=10, style=filled]
    edge [fontname="Helvetica", fontsize=9, color="#555555"]

    // =========================================================================
    // The dot-graph bundle (source of capabilities)
    // =========================================================================

    subgraph cluster_dot_graph_bundle {
        label=<<B>amplifier-bundle-dot-graph</B><BR/>
               <FONT POINT-SIZE="9">github.com/microsoft/amplifier-bundle-dot-graph</FONT>>
        style=rounded
        color="#1565C0"
        penwidth=3
        bgcolor="#E3F2FD"

        dg_bundle [label=<<B>bundle.md</B><BR/>
                    <FONT POINT-SIZE="9">name: dot-graph  v0.1.0</FONT>>,
                    shape=tab, fillcolor="#BBDEFB", color="#1565C0"]

        subgraph cluster_dg_behavior {
            label=<<B>behaviors/dot-graph.yaml</B>>
            style=rounded
            color="#1976D2"
            bgcolor="#BBDEFB"

            dg_behavior [label=<<B>dot-graph behavior</B><BR/>
                          <FONT POINT-SIZE="9">Composable unit:<BR/>
                          agents + tools + context</FONT>>,
                          shape=component, fillcolor="#90CAF9", color="#1565C0"]
        }

        dg_bundle -> dg_behavior [label="includes", color="#1565C0"]

        // Capabilities shipped by the behavior
        subgraph cluster_dg_caps {
            label=<<B>Capabilities (shipped)</B>>
            style=rounded
            color="#0288D1"
            bgcolor="#E1F5FE"

            cap_author   [label=<<B>dot-author</B><BR/><FONT POINT-SIZE="9">Agent</FONT>>,
                          shape=box, style="rounded,filled", fillcolor="#FFE0B2", color="#E65100"]
            cap_reviewer [label=<<B>diagram-reviewer</B><BR/><FONT POINT-SIZE="9">Agent</FONT>>,
                          shape=box, style="rounded,filled", fillcolor="#FFCCBC", color="#BF360C"]
            cap_tools    [label=<<B>dot_validate · dot_render<BR/>dot_setup · dot_analyze</B><BR/><FONT POINT-SIZE="9">Tool functions</FONT>>,
                          shape=ellipse, fillcolor="#C8E6C9", color="#2E7D32"]
            cap_awareness [label=<<B>dot-awareness.md</B><BR/><FONT POINT-SIZE="9">Context (always loaded)</FONT>>,
                           shape=note, fillcolor="#B2EBF2", color="#0097A7"]
            cap_skills   [label=<<B>5 skills</B><BR/><FONT POINT-SIZE="9">On-demand knowledge</FONT>>,
                          shape=tab, fillcolor="#E3F2FD", color="#1976D2"]
        }

        dg_behavior -> cap_author    [style=dashed, color="#E65100"]
        dg_behavior -> cap_reviewer  [style=dashed, color="#BF360C"]
        dg_behavior -> cap_tools     [style=dashed, color="#2E7D32"]
        dg_behavior -> cap_awareness [style=dashed, color="#0097A7"]
        dg_behavior -> cap_skills    [style=dashed, color="#1976D2"]
    }

    // =========================================================================
    // Bundles that include the dot-graph behavior
    // =========================================================================

    subgraph cluster_consumers {
        label=<<B>Bundles That Include dot-graph behavior</B>>
        style=rounded
        color="#6A1B9A"
        penwidth=2
        bgcolor="#F3E5F5"

        // foundation bundle
        subgraph cluster_foundation {
            label=<<B>amplifier-foundation</B><BR/>
                   <FONT POINT-SIZE="9">Core platform bundle</FONT>>
            style=rounded
            color="#7B1FA2"
            bgcolor="#EDE7F6"

            found_bundle [label=<<B>foundation bundle</B><BR/>
                           <FONT POINT-SIZE="9">Orchestration · Recipes<BR/>
                           Validation agents</FONT>>,
                           shape=tab, fillcolor="#D1C4E9", color="#6A1B9A"]
            found_agents [label=<<B>zen-architect<BR/>code-analyst</B><BR/>
                           <FONT POINT-SIZE="9">+ dot-graph agents</FONT>>,
                           shape=box, style="rounded,filled", fillcolor="#CE93D8"]
        }

        // dot-graph-bundle (dev environment — THIS REPO)
        subgraph cluster_dgbundle {
            label=<<B>dot-graph-bundle</B><BR/>
                   <FONT POINT-SIZE="9">Development environment<BR/>(this repository)</FONT>>
            style=rounded
            color="#AD1457"
            bgcolor="#FCE4EC"

            dgb_bundle [label=<<B>amplifier-dev behavior</B><BR/>
                         <FONT POINT-SIZE="9">Full dev environment<BR/>
                         Includes foundation</FONT>>,
                         shape=tab, fillcolor="#F8BBD9", color="#AD1457"]
            dgb_session [label=<<B>Active session</B><BR/>
                          <FONT POINT-SIZE="9">dot-author available<BR/>
                          diagram-reviewer available<BR/>
                          dot_validate · dot_render</FONT>>,
                          shape=box, style="rounded,filled", fillcolor="#F48FB1"]
        }

        // Hypothetical: team bundle example
        subgraph cluster_team_bundle {
            label=<<B>your-team-bundle</B><BR/>
                   <FONT POINT-SIZE="9">Example: any team adopting it</FONT>>
            style="rounded,dashed"
            color="#00695C"
            bgcolor="#E0F2F1"

            team_bundle [label=<<B>bundle.md</B><BR/>
                          <FONT POINT-SIZE="9">includes: dot-graph:behaviors/dot-graph</FONT>>,
                          shape=tab, fillcolor="#B2DFDB", color="#00695C"]
            team_gain   [label=<<B>Gains:</B><BR/>
                          <FONT POINT-SIZE="9">• DOT authoring agent<BR/>
                          • Quality review agent<BR/>
                          • Graphviz tools<BR/>
                          • DOT awareness context</FONT>>,
                          shape=box, style="rounded,filled", fillcolor="#A5D6A7"]
        }
    }

    // Composition edges
    found_bundle -> dg_behavior [label="includes", penwidth=2, color="#7B1FA2",
                                   lhead=cluster_dg_behavior]
    dgb_bundle   -> dg_behavior [label="includes\n(via foundation)", penwidth=2, color="#AD1457",
                                   lhead=cluster_dg_behavior]
    team_bundle  -> dg_behavior [label="includes", penwidth=2, color="#00695C",
                                   lhead=cluster_dg_behavior, style=dashed]

    // Capabilities flow downstream
    dg_behavior -> found_agents [label="adds", color="#7B1FA2", style=dashed]
    dg_behavior -> dgb_session  [label="adds", color="#AD1457", style=dashed]
    dg_behavior -> team_gain    [label="adds", color="#00695C", style=dashed]

    // =========================================================================
    // Context sink pattern
    // =========================================================================

    subgraph cluster_context_sink {
        label=<<B>Context Sink Pattern</B><BR/>
               <FONT POINT-SIZE="9">How dot-awareness reaches every session</FONT>>
        style=rounded
        color="#E65100"
        penwidth=2
        bgcolor="#FFF3E0"

        sink_root [label=<<B>Root behavior</B><BR/>
                    <FONT POINT-SIZE="9">Always-loaded base context<BR/>
                    e.g. amplifier-dev.yaml</FONT>>,
                    shape=component, fillcolor="#FFE0B2"]

        sink_dot_ctx [label=<<B>dot-awareness.md</B><BR/>
                       <FONT POINT-SIZE="9">Injected via behavior include<BR/>
                       Every session knows DOT exists<BR/>
                       Delegates to dot-author/reviewer</FONT>>,
                       shape=note, fillcolor="#FFF9C4", color="#F57F17"]

        sink_agent_ctx [label=<<B>Agent sessions</B><BR/>
                         <FONT POINT-SIZE="9">dot-author loads skills on demand<BR/>
                         diagram-reviewer loads quality docs<BR/>
                         Context only when needed</FONT>>,
                         shape=box, style="rounded,filled", fillcolor="#FFCCBC"]

        sink_root -> sink_dot_ctx   [label="behavior includes\ncontext file", penwidth=2, color="#E65100"]
        sink_dot_ctx -> sink_agent_ctx [label="delegates to\nagents", style=dashed, color="#F57F17"]
    }

    // Adoption path starts from including the behavior
    team_bundle -> adopt_add_bundle [label="  follow\nadoption path", style=dotted, color="#607D8B", constraint=false]

    // Context sink connects to bundle
    cap_awareness -> sink_dot_ctx [label="same file", style=dotted, color="#90A4AE", constraint=false]

    // =========================================================================
    // Adoption gradient
    // =========================================================================

    subgraph cluster_adoption {
        label=<<B>Adoption Path</B>>
        style=rounded
        color="#607D8B"
        bgcolor="#FAFAFA"

        adopt_add_bundle [label=<<B>Step 1</B><BR/><FONT POINT-SIZE="9">Add to bundle.md:<BR/><I>includes: dot-graph:behaviors/dot-graph</I></FONT>>,
            shape=box, style="rounded,filled", fillcolor="#F5F5F5", color="#607D8B"]
        adopt_loads_context [label=<<B>Step 2</B><BR/><FONT POINT-SIZE="9">Session auto-loads<BR/>dot-awareness.md context</FONT>>,
            shape=box, style="rounded,filled", fillcolor="#F5F5F5", color="#607D8B"]
        adopt_delegate_authoring [label=<<B>Step 3</B><BR/><FONT POINT-SIZE="9">Delegate DOT authoring<BR/>to dot-author agent</FONT>>,
            shape=box, style="rounded,filled", fillcolor="#FFE0B2", color="#E65100"]
        adopt_review_quality [label=<<B>Step 4</B><BR/><FONT POINT-SIZE="9">Review with<BR/>diagram-reviewer agent</FONT>>,
            shape=box, style="rounded,filled", fillcolor="#FFCCBC", color="#BF360C"]

        adopt_add_bundle -> adopt_loads_context -> adopt_delegate_authoring -> adopt_review_quality [penwidth=2]
    }

    // =========================================================================
    // Legend
    // =========================================================================

    subgraph cluster_legend {
        label=<<B>Legend</B>>
        style=rounded
        color="#9E9E9E"
        bgcolor="#FAFAFA"
        fontsize=10
        node [fontsize=9, height=0.3]

        l_bundle  [label="Bundle manifest",       shape=tab,       fillcolor="#D1C4E9", width=1.8]
        l_behav   [label="Behavior (wiring unit)", shape=component, fillcolor="#90CAF9", width=1.8]
        l_agent   [label="Agent (delegatable)",    shape=box, style="rounded,filled", fillcolor="#FFE0B2", width=1.8]
        l_tool    [label="Tool functions",         shape=ellipse,   fillcolor="#C8E6C9", width=1.8]
        l_ctx     [label="Context / awareness",    shape=note,      fillcolor="#B2EBF2", width=1.8]
        l_solid   [label="Hard include",           shape=plaintext, fillcolor="white",   width=1.8]
        l_dashed  [label="Soft reference / gain",  shape=plaintext, fillcolor="white",   width=1.8]
        l_dotted  [label="Cross-ref / annotation",   shape=plaintext, fillcolor="white",   width=1.8]

        l_bundle -> l_behav -> l_agent -> l_tool -> l_ctx -> l_solid -> l_dashed -> l_dotted [style=invis]
    }
}
