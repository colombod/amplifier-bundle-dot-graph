// Demo 4a: Multi-Scale Navigation — OVERVIEW
// Demonstrates: DOT as multi-scale navigation (zoom-out view)
// System: cloud-native SaaS platform (5 major subsystems, key cross-cutting edges)

digraph multiscale_overview {
    rankdir=TB
    compound=true
    fontname="Helvetica"
    fontsize=14
    label=<<B>CloudSaaS Platform — Overview</B><BR/>
           <FONT POINT-SIZE="11">System-level view: 5 subsystems · Key data flows · See detail files for internals</FONT>>
    labelloc=t
    labeljust=c
    pad=0.6
    nodesep=0.6
    ranksep=0.9
    bgcolor="white"

    node [fontname="Helvetica", fontsize=10, style=filled]
    edge [fontname="Helvetica", fontsize=9, color="#555555"]

    // =========================================================================
    // External actors
    // =========================================================================

    subgraph cluster_external {
        label=<<B>External</B>>
        style=rounded
        color="#607D8B"
        bgcolor="#ECEFF1"

        web_client  [label=<<B>Web Client</B><BR/><FONT POINT-SIZE="9">React SPA</FONT>>,
                     shape=box, style="rounded,filled", fillcolor="#CFD8DC"]
        mobile_app  [label=<<B>Mobile App</B><BR/><FONT POINT-SIZE="9">iOS / Android</FONT>>,
                     shape=box, style="rounded,filled", fillcolor="#CFD8DC"]
        partner_api [label=<<B>Partner APIs</B><BR/><FONT POINT-SIZE="9">Third-party integrations</FONT>>,
                     shape=box, style="rounded,filled", fillcolor="#CFD8DC"]
    }

    // =========================================================================
    // Subsystem 1: Gateway & Auth
    // =========================================================================

    subgraph cluster_gateway {
        label=<<B>Gateway &amp; Auth</B><BR/><FONT POINT-SIZE="9">see: 04b-multiscale-detail.dot</FONT>>
        style=rounded
        color="#1565C0"
        penwidth=2
        bgcolor="#E3F2FD"

        gw_node [label=<<B>API Gateway</B><BR/><FONT POINT-SIZE="9">Rate limiting · Routing<BR/>JWT validation · TLS</FONT>>,
                  shape=box, style="rounded,filled", fillcolor="#BBDEFB"]
    }

    // =========================================================================
    // Subsystem 2: Core Platform Services
    // =========================================================================

    subgraph cluster_platform {
        label=<<B>Core Platform</B>>
        style=rounded
        color="#2E7D32"
        penwidth=2
        bgcolor="#E8F5E9"

        user_svc    [label=<<B>User Service</B><BR/><FONT POINT-SIZE="9">Profiles · Orgs</FONT>>,
                     shape=box, style="rounded,filled", fillcolor="#C8E6C9"]
        tenant_svc  [label=<<B>Tenant Service</B><BR/><FONT POINT-SIZE="9">Multi-tenancy · Billing</FONT>>,
                     shape=box, style="rounded,filled", fillcolor="#C8E6C9"]
        feature_flags [label=<<B>Feature Flags</B><BR/><FONT POINT-SIZE="9">Rollout control</FONT>>,
                       shape=box, style="rounded,filled", fillcolor="#C8E6C9"]
    }

    // =========================================================================
    // Subsystem 3: Product Domain
    // =========================================================================

    subgraph cluster_product {
        label=<<B>Product Domain</B>>
        style=rounded
        color="#E65100"
        penwidth=2
        bgcolor="#FFF3E0"

        catalog_svc  [label=<<B>Catalog Service</B><BR/><FONT POINT-SIZE="9">Products · Pricing</FONT>>,
                      shape=box, style="rounded,filled", fillcolor="#FFE0B2"]
        order_svc    [label=<<B>Order Service</B><BR/><FONT POINT-SIZE="9">Orders · Fulfilment</FONT>>,
                      shape=box, style="rounded,filled", fillcolor="#FFE0B2"]
        inventory_svc [label=<<B>Inventory Service</B><BR/><FONT POINT-SIZE="9">Stock levels</FONT>>,
                       shape=box, style="rounded,filled", fillcolor="#FFE0B2"]
    }

    // =========================================================================
    // Subsystem 4: Data Layer
    // =========================================================================

    subgraph cluster_data {
        label=<<B>Data Layer</B>>
        style=rounded
        color="#6A1B9A"
        penwidth=2
        bgcolor="#F3E5F5"

        primary_db   [label=<<B>Primary DB</B><BR/><FONT POINT-SIZE="9">PostgreSQL (HA)</FONT>>,
                      shape=cylinder, fillcolor="#E1BEE7"]
        read_replica [label=<<B>Read Replicas</B><BR/><FONT POINT-SIZE="9">3x · auto-failover</FONT>>,
                      shape=cylinder, fillcolor="#E1BEE7"]
        cache_layer  [label=<<B>Cache Layer</B><BR/><FONT POINT-SIZE="9">Redis Cluster</FONT>>,
                      shape=cylinder, fillcolor="#CE93D8"]
        event_bus    [label=<<B>Event Bus</B><BR/><FONT POINT-SIZE="9">Kafka · 8 topics</FONT>>,
                      shape=cylinder, fillcolor="#CE93D8"]
    }

    // =========================================================================
    // Subsystem 5: Observability
    // =========================================================================

    subgraph cluster_obs {
        label=<<B>Observability</B>>
        style=rounded
        color="#00695C"
        penwidth=2
        bgcolor="#E0F2F1"

        metrics   [label=<<B>Metrics</B><BR/><FONT POINT-SIZE="9">Prometheus</FONT>>,
                   shape=box, style="rounded,filled", fillcolor="#B2DFDB"]
        tracing   [label=<<B>Tracing</B><BR/><FONT POINT-SIZE="9">Jaeger · OpenTelemetry</FONT>>,
                   shape=box, style="rounded,filled", fillcolor="#B2DFDB"]
        log_agg   [label=<<B>Log Aggregation</B><BR/><FONT POINT-SIZE="9">Loki · Grafana</FONT>>,
                   shape=box, style="rounded,filled", fillcolor="#B2DFDB"]
    }

    // =========================================================================
    // Cross-system edges (key flows only — detail in 04b)
    // =========================================================================

    web_client  -> gw_node [label="HTTPS", penwidth=2]
    mobile_app  -> gw_node [label="HTTPS", penwidth=2]
    partner_api -> gw_node [label="HTTPS/mTLS", style=dashed]

    gw_node -> user_svc   [label="authn", penwidth=2]
    gw_node -> tenant_svc [label="authz"]
    gw_node -> catalog_svc  [label="route", penwidth=2]
    gw_node -> order_svc    [label="route", penwidth=2]

    user_svc   -> primary_db  [label="r/w"]
    tenant_svc -> primary_db  [label="r/w"]
    catalog_svc -> read_replica [label="read"]
    order_svc   -> primary_db  [label="r/w", penwidth=2]
    order_svc   -> cache_layer  [label="session"]
    order_svc   -> event_bus    [label="emit", penwidth=2]
    inventory_svc -> primary_db [label="r/w"]

    event_bus -> catalog_svc   [label="sync", style=dashed]
    event_bus -> inventory_svc [label="restock", style=dashed]
    feature_flags -> gw_node   [label="config", style=dotted]
    feature_flags -> user_svc  [label="config", style=dotted]

    primary_db -> read_replica [label="replication", style=dashed, color="#9E9E9E"]

    // Observability: all services emit to obs cluster
    gw_node   -> metrics [style=dotted, color="#80CBC4"]
    order_svc -> tracing  [style=dotted, color="#80CBC4"]
    gw_node   -> log_agg  [style=dotted, color="#80CBC4"]

    // =========================================================================
    // Legend
    // =========================================================================

    subgraph cluster_legend {
        label=<<B>Legend</B>>
        style=rounded
        color="#9E9E9E"
        bgcolor="#FAFAFA"
        fontsize=10
        node [fontsize=9, height=0.3]

        l_svc    [label="Service",       shape=box, style="rounded,filled", fillcolor="#C8E6C9", width=1.6]
        l_store  [label="Data store",    shape=cylinder, fillcolor="#E1BEE7", width=1.6]
        l_sync   [label="Sync call",     shape=plaintext, fillcolor="white", width=1.6]
        l_async  [label="Async / event", shape=plaintext, fillcolor="white", width=1.6]
        l_cfg    [label="Config signal", shape=plaintext, fillcolor="white", width=1.6]

        l_svc -> l_store -> l_sync -> l_async -> l_cfg [style=invis]
    }
}
