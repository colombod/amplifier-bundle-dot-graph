// Demo 3b: Reconciliation — AFTER (reconciled graph surfacing real issues)
// Demonstrates: DOT as reconciliation forcing function
// Reality revealed: dead code, missing retry, sync-not-async, undocumented dep

digraph reconciliation_after {
    rankdir=LR
    compound=true
    fontname="Helvetica"
    fontsize=14
    label=<<B>Order Processing System — AFTER Reconciliation</B><BR/>
           <FONT POINT-SIZE="11" COLOR="#1B5E20">Reality surfaced: dead code, missing retry, sync queue, undocumented deps</FONT>>
    labelloc=t
    labeljust=c
    pad=0.6
    nodesep=0.5
    ranksep=0.7
    bgcolor="white"

    node [fontname="Helvetica", fontsize=10, style=filled]
    edge [fontname="Helvetica", fontsize=9, color="#555555"]

    // =========================================================================
    // Ingestion layer
    // =========================================================================

    subgraph cluster_ingestion {
        label=<<B>Ingestion</B>>
        style=rounded
        color="#1565C0"
        penwidth=2
        bgcolor="#E3F2FD"

        api_gateway [label=<<B>API Gateway</B><BR/><FONT POINT-SIZE="9">Routes incoming orders</FONT>>,
                     shape=box, style="rounded,filled", fillcolor="#BBDEFB"]
        order_api   [label=<<B>Order API</B><BR/><FONT POINT-SIZE="9">POST /orders endpoint</FONT>>,
                     shape=box, style="rounded,filled", fillcolor="#BBDEFB"]

        // FINDING: auth_svc delegates to external IdP — not in-house JWT validation
        auth_svc    [label=<<B>Auth Service</B><BR/>
                     <FONT POINT-SIZE="9" COLOR="#E65100">⚠ DELEGATES to external IdP<BR/>
                     Not self-contained as believed</FONT>>,
                     shape=box, style="rounded,filled", fillcolor="#FFE0B2", color="#E65100", penwidth=2]

    }

    // External IdP placed OUTSIDE all clusters — emphasises it's uncontrolled/external (Finding #4)
    ext_idp     [label=<<B>External IdP</B><BR/><FONT POINT-SIZE="9">Auth0 / undocumented dep<BR/>
                 <B>NOT in-house</B></FONT>>,
                 shape=box, style="rounded,filled", fillcolor="#FFCCBC", color="#BF360C"]

    // =========================================================================
    // Processing layer
    // =========================================================================

    subgraph cluster_processing {
        label=<<B>Processing</B>>
        style=rounded
        color="#2E7D32"
        penwidth=2
        bgcolor="#E8F5E9"

        order_validator [label=<<B>Order Validator</B><BR/><FONT POINT-SIZE="9">Validates schema</FONT>>,
                         shape=box, style="rounded,filled", fillcolor="#C8E6C9"]
        inventory_svc   [label=<<B>Inventory Service</B><BR/><FONT POINT-SIZE="9">Checks stock</FONT>>,
                         shape=box, style="rounded,filled", fillcolor="#C8E6C9"]
        pricing_engine  [label=<<B>Pricing Engine</B><BR/><FONT POINT-SIZE="9">Applies discounts</FONT>>,
                         shape=box, style="rounded,filled", fillcolor="#C8E6C9"]

        // FINDING: payment_svc has NO retry logic — direct failure returns error
        payment_svc     [label=<<B>Payment Service</B><BR/>
                         <FONT POINT-SIZE="9" COLOR="#B71C1C">✗ NO RETRY LOGIC<BR/>
                         Transient failures → silent drop</FONT>>,
                         shape=box, style="rounded,filled", fillcolor="#FFCDD2", color="#C62828", penwidth=2]

        // FINDING: retry_logic module exists in codebase but is NEVER CALLED
        retry_logic     [label=<<B>Retry Logic</B><BR/>
                         <FONT POINT-SIZE="9" COLOR="#9E9E9E">☠ DEAD CODE<BR/>
                         Module exists but never invoked<BR/>
                         Unreachable from any caller</FONT>>,
                         shape=box, style="dashed,filled", fillcolor="#EEEEEE", color="#9E9E9E",
                         penwidth=2, fontcolor="#9E9E9E"]
    }

    // =========================================================================
    // Fulfilment layer
    // =========================================================================

    subgraph cluster_fulfilment {
        label=<<B>Fulfilment</B>>
        style=rounded
        color="#E65100"
        penwidth=2
        bgcolor="#FFF3E0"

        fulfilment_svc   [label=<<B>Fulfilment Service</B><BR/><FONT POINT-SIZE="9">Creates shipment record</FONT>>,
                          shape=box, style="rounded,filled", fillcolor="#FFE0B2"]
        shipping_api     [label=<<B>Shipping API</B><BR/><FONT POINT-SIZE="9">(external)</FONT>>,
                          shape=box, style="rounded,filled", fillcolor="#FFCCBC"]

        // FINDING: notification_svc only sends email — SMS silently dropped
        notification_svc [label=<<B>Notification Service</B><BR/>
                          <FONT POINT-SIZE="9" COLOR="#E65100">⚠ EMAIL ONLY<BR/>
                          SMS path removed but callers unchanged</FONT>>,
                          shape=box, style="rounded,filled", fillcolor="#FFE0B2", color="#E65100", penwidth=2]
    }

    // =========================================================================
    // Data stores
    // =========================================================================

    subgraph cluster_stores {
        label=<<B>Data Stores</B>>
        style=rounded
        color="#6A1B9A"
        penwidth=2
        bgcolor="#F3E5F5"

        order_db    [label=<<B>Orders DB</B><BR/><FONT POINT-SIZE="9">PostgreSQL</FONT>>,
                     shape=cylinder, fillcolor="#E1BEE7"]

        // FINDING: cache is never populated — every request is a cold miss
        cache       [label=<<B>Cache</B><BR/>
                     <FONT POINT-SIZE="9" COLOR="#B71C1C">✗ NEVER WARMED<BR/>
                     Written but never read<BR/>
                     100% cold miss rate</FONT>>,
                     shape=cylinder, fillcolor="#FFCDD2", color="#C62828", penwidth=2]

        // FINDING: event_queue is called SYNCHRONOUSLY — blocks main thread
        event_queue [label=<<B>Event Queue</B><BR/>
                     <FONT POINT-SIZE="9" COLOR="#B71C1C">✗ SYNC NOT ASYNC<BR/>
                     Blocking call on payment path<BR/>
                     Kafka SDK used synchronously</FONT>>,
                     shape=cylinder, fillcolor="#FFCDD2", color="#C62828", penwidth=2]
    }

    // =========================================================================
    // Analytics — DEAD CLUSTER (no live connections)
    // =========================================================================

    subgraph cluster_analytics {
        label=<<B>Analytics ☠ DISCONNECTED</B>>
        style="rounded,dashed"
        color="#9E9E9E"
        penwidth=2
        bgcolor="#F5F5F5"

        analytics_svc [label=<<B>Analytics Service</B><BR/>
                       <FONT POINT-SIZE="9" COLOR="#9E9E9E">☠ NEVER RECEIVES EVENTS<BR/>
                       event_queue → analytics path<BR/>
                       removed in commit a3f2c</FONT>>,
                       shape=box, style="dashed,filled", fillcolor="#EEEEEE",
                       color="#9E9E9E", fontcolor="#9E9E9E"]
        reporting_db  [label=<<B>Reporting DB</B><BR/>
                       <FONT POINT-SIZE="9" COLOR="#9E9E9E">☠ STALE — last write 47 days ago</FONT>>,
                       shape=cylinder, fillcolor="#EEEEEE", color="#9E9E9E"]

        analytics_svc -> reporting_db [style=dashed, color="#BDBDBD"]
    }

    // =========================================================================
    // Actual flow (reconciled)
    // =========================================================================

    api_gateway   -> order_api       [label="route"]
    api_gateway   -> auth_svc        [label="validate token"]
    auth_svc      -> ext_idp         [label="delegates JWT\nvalidation", color="#E65100", style=dashed]
    auth_svc      -> order_api       [label="authorized"]
    order_api     -> order_validator [label="validate"]
    order_api     -> cache           [label="write-only\n(never read)", color="#EF9A9A", style=dashed]
    order_validator -> inventory_svc  [label="check stock"]
    inventory_svc   -> pricing_engine [label="priced"]
    pricing_engine  -> payment_svc   [label="charge"]
    payment_svc     -> order_db      [label="record"]
    payment_svc     -> event_queue   [label="BLOCKING call", color="#C62828", penwidth=2]
    event_queue     -> fulfilment_svc [label="triggers\n(synchronous)"]
    fulfilment_svc  -> shipping_api  [label="shipment"]
    fulfilment_svc  -> notification_svc [label="notify"]

    // Cache is a write-only dead end — self-loop documents there is no reader
    cache -> cache [label="write-only\nno readers", style=dashed, color="#9E9E9E"]

    // Dead code annotation — retry_logic is unreachable but exists in codebase
    payment_svc -> retry_logic [label="should call\n(never does)", style=dashed, color="#BDBDBD", constraint=false]

    // Findings summary connects to the cluster root
    payment_svc -> findings [label="7 issues\nfound", style=dotted, color="#B71C1C", constraint=false]

    // =========================================================================
    // Findings summary
    // =========================================================================

    subgraph cluster_findings {
        label=<<B>Reconciliation Findings</B>>
        style=rounded
        color="#B71C1C"
        bgcolor="#FFEBEE"
        fontsize=10

        findings [label=<
            <TABLE BORDER="0" CELLBORDER="1" CELLSPACING="2" CELLPADDING="4">
            <TR><TD BGCOLOR="#FFCDD2"><B>Finding</B></TD><TD BGCOLOR="#FFCDD2"><B>Impact</B></TD></TR>
            <TR><TD ALIGN="LEFT">✗ payment_svc: no retry logic</TD><TD ALIGN="LEFT">Silent transaction drops</TD></TR>
            <TR><TD ALIGN="LEFT">✗ event_queue: synchronous not async</TD><TD ALIGN="LEFT">Blocks payment thread</TD></TR>
            <TR><TD ALIGN="LEFT">✗ cache: write-only, never read</TD><TD ALIGN="LEFT">Wasted CPU + memory</TD></TR>
            <TR><TD ALIGN="LEFT">⚠ auth_svc: undocumented IdP dep</TD><TD ALIGN="LEFT">Hidden outage risk</TD></TR>
            <TR><TD ALIGN="LEFT">⚠ notification_svc: SMS silently removed</TD><TD ALIGN="LEFT">Broken customer promise</TD></TR>
            <TR><TD ALIGN="LEFT">☠ retry_logic: dead code module</TD><TD ALIGN="LEFT">Maintenance confusion</TD></TR>
            <TR><TD ALIGN="LEFT">☠ analytics cluster: disconnected</TD><TD ALIGN="LEFT">Stale reporting data</TD></TR>
            </TABLE>>,
            shape=box, fillcolor="#FFEBEE", color="#B71C1C"]
    }

    // =========================================================================
    // Legend
    // =========================================================================

    subgraph cluster_legend {
        label=<<B>Legend</B>>
        style=rounded
        color="#9E9E9E"
        bgcolor="#FAFAFA"
        fontsize=10
        node [fontsize=9, height=0.3]

        l_ok    [label="Verified correct",       shape=box, style="rounded,filled", fillcolor="#C8E6C9", color="#2E7D32", width=1.9]
        l_warn  [label="⚠ Differs from belief",  shape=box, style="rounded,filled", fillcolor="#FFE0B2", color="#E65100", width=1.9]
        l_error [label="✗ Missing / wrong",      shape=box, style="rounded,filled", fillcolor="#FFCDD2", color="#C62828", width=1.9]
        l_dead  [label="☠ Dead code / orphaned", shape=box, style="dashed,filled",  fillcolor="#EEEEEE", color="#9E9E9E", width=1.9]

        l_ok -> l_warn -> l_error -> l_dead [style=invis]

        // Edge style key
        l_e_solid  [label="─── Live call / data flow",  shape=plaintext, fontsize=9, width=2.1]
        l_e_dashed [label="- - Dead / conditional / delegated", shape=plaintext, fontsize=9, width=2.1]
        l_e_dotted [label="···· Reference / annotation",  shape=plaintext, fontsize=9, width=2.1]
        l_e_bold   [label="━━━ Blocking / critical path", shape=plaintext, fontsize=9, width=2.1]
        l_dead -> l_e_solid [style=invis]
        l_e_solid -> l_e_dashed -> l_e_dotted -> l_e_bold [style=invis]
    }
}
