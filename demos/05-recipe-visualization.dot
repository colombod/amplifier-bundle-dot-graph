// Amplifier Foundation — Bundle Validation Recipes
// Three related recipes forming a validation family:
//   1. validate-bundle.yaml (v2.0.0) — Multi-bundle orchestrator
//   2. validate-single-bundle.yaml (v2.0.0) — Per-bundle worker (sub-recipe)
//   3. validate-bundle-repo.yaml (v3.2.0) — Full repo structural validator (independent)

digraph bundle_validation_recipes {
    rankdir=TB
    compound=true
    fontname="Helvetica"
    fontsize=14
    label=<<B>Amplifier Foundation — Bundle Validation Recipes</B>>
    labelloc=t
    labeljust=c
    pad=0.5
    nodesep=0.5
    ranksep=0.6

    // ========================================================================
    // Global styles
    // ========================================================================

    node [fontname="Helvetica", fontsize=10, style=filled]
    edge [fontname="Helvetica", fontsize=9]

    // Step type colors
    // bash steps: light blue
    // agent steps: light green
    // recipe steps (sub-recipe): light orange
    // foreach steps: light purple
    // conditional gates: diamond, light yellow
    // default/init steps: light gray

    // ========================================================================
    // RECIPE 1: validate-bundle.yaml (v2.0.0)
    // Multi-bundle orchestrator — discovers bundles, calls sub-recipe per bundle
    // ========================================================================

    subgraph cluster_validate_bundle {
        label=<<B>validate-bundle.yaml</B> v2.0.0<BR/><I>Multi-Bundle Validator with Dependency Tracing</I>>
        style=rounded
        color="#2196F3"
        penwidth=2
        fontsize=12
        bgcolor="#E3F2FD"

        // Nodes
        vb_env [label=<<B>environment-check</B><BR/>Check/auto-install<BR/>amplifier_foundation<BR/><I>timeout: 180s</I>>, shape=box, fillcolor="#BBDEFB"]
        vb_discover [label=<<B>discover-bundles</B><BR/>Find root bundle.md +<BR/>/bundles/* standalones<BR/><I>timeout: 30s</I>>, shape=box, fillcolor="#BBDEFB"]
        vb_foreach [label=<<B>validate-bundles</B><BR/>foreach: discovery.bundles<BR/>collect → bundle_results<BR/><I>sequential, timeout: 600s</I>>, shape=hexagon, fillcolor="#E1BEE7"]
        vb_synth [label=<<B>synthesize-report</B><BR/>foundation:zen-architect<BR/>ANALYZE mode<BR/><I>timeout: 300s</I>>, shape=box, fillcolor="#C8E6C9"]

        // Edges
        vb_env -> vb_discover
        vb_discover -> vb_foreach
        vb_foreach -> vb_synth
    }

    // ========================================================================
    // RECIPE 2: validate-single-bundle.yaml (v2.0.0)
    // Per-bundle worker — called as sub-recipe via foreach
    // ========================================================================

    subgraph cluster_validate_single {
        label=<<B>validate-single-bundle.yaml</B> v2.0.0<BR/><I>Single Bundle Validator (Sub-Recipe)</I>>
        style="rounded,dashed"
        color="#FF9800"
        penwidth=2
        fontsize=12
        bgcolor="#FFF3E0"

        // Nodes
        vs_trace [label=<<B>trace-dependencies</B><BR/>Walk includes: DAG<BR/>Resolve local behaviors<BR/>Extract @mentions<BR/><I>timeout: 60s</I>>, shape=box, fillcolor="#FFE0B2"]
        vs_context [label=<<B>context-analysis</B><BR/>Token counting (len//4)<BR/>Per-file: ⚠4K / 🚫8K<BR/>Total: ⚠8K / 🚫16K<BR/><I>timeout: 60s</I>>, shape=box, fillcolor="#FFE0B2"]
        vs_report [label=<<B>generate-report</B><BR/>foundation:zen-architect<BR/>ANALYZE mode<BR/>Verdict: PASS/FAIL/WARN<BR/><I>timeout: 180s</I>>, shape=box, fillcolor="#C8E6C9"]

        // Edges
        vs_trace -> vs_context
        vs_context -> vs_report
    }

    // Sub-recipe call edge
    vb_foreach -> vs_trace [label="  calls per bundle  ", style=dashed, color="#FF9800", penwidth=2, lhead=cluster_validate_single]

    // ========================================================================
    // RECIPE 3: validate-bundle-repo.yaml (v3.2.0)
    // Full repo structural validator — independent, comprehensive
    // ========================================================================

    subgraph cluster_validate_repo {
        label=<<B>validate-bundle-repo.yaml</B> v3.2.0<BR/><I>Repository-Wide Structural Validator (Independent)</I>>
        style=rounded
        color="#4CAF50"
        penwidth=2
        fontsize=12
        bgcolor="#E8F5E9"

        // ── Phase 0: Environment ──
        subgraph cluster_phase0 {
            label="Phase 0: Environment"
            style=rounded
            color="#78909C"
            bgcolor="#ECEFF1"

            vr_env [label=<<B>environment-check</B><BR/>Detect foundation, hatchling,<BR/>pip wheel capability<BR/>→ validation_mode<BR/><I>timeout: 30s</I>>, shape=box, fillcolor="#BBDEFB"]
        }

        // ── Phase 0.5–0.7: Packaging ──
        subgraph cluster_packaging {
            label="Phase 0.5–0.7: Packaging"
            style=rounded
            color="#78909C"
            bgcolor="#ECEFF1"

            vr_pkg [label=<<B>packaging-check</B><BR/>pyproject.toml<BR/>force-include paths<BR/><I>timeout: 30s</I>>, shape=box, fillcolor="#BBDEFB"]

            vr_build_gate [label="has_pyproject?", shape=diamond, fillcolor="#FFF9C4"]

            vr_build [label=<<B>build-check</B><BR/>pip wheel --no-deps<BR/>dry-run (graceful skip)<BR/><I>timeout: 180s</I>>, shape=box, fillcolor="#BBDEFB"]
            vr_build_default [label=<<B>set-default-build-check</B><BR/>No pyproject.toml<BR/>→ skipped/passed<BR/><I>timeout: 10s</I>>, shape=box, fillcolor="#E0E0E0"]

            vr_pkg -> vr_build_gate
            vr_build_gate -> vr_build [label="true"]
            vr_build_gate -> vr_build_default [label="false"]
        }

        // ── Phase 1: Discovery ──
        subgraph cluster_phase1 {
            label="Phase 1: Discovery"
            style=rounded
            color="#78909C"
            bgcolor="#ECEFF1"

            vr_disco [label=<<B>repo-discovery</B><BR/>Find root, behaviors,<BR/>standalone, experiments,<BR/>providers, agents<BR/><I>timeout: 60s</I>>, shape=box, fillcolor="#BBDEFB"]
        }

        // ── Phase 2: Validation Battery ──
        subgraph cluster_phase2 {
            label="Phase 2: Validation Battery"
            style=rounded
            color="#78909C"
            bgcolor="#ECEFF1"

            vr_val_all [label=<<B>validate-all-bundles</B><BR/>BundleRegistry per-bundle<BR/>load test (async)<BR/><I>timeout: 300s, on_error: continue</I>>, shape=box, fillcolor="#BBDEFB"]

            vr_hygiene [label=<<B>behavior-hygiene</B><BR/>No root includes<BR/>Context token limits<BR/><I>timeout: 120s</I>>, shape=box, fillcolor="#BBDEFB"]

            vr_standalone [label=<<B>standalone-completeness</B><BR/>Orchestrator + session<BR/>config required<BR/><I>timeout: 180s</I>>, shape=box, fillcolor="#BBDEFB"]

            vr_experiments [label=<<B>experiments-validation</B><BR/>Naming, EXPERIMENTAL<BR/>warning presence<BR/><I>timeout: 120s</I>>, shape=box, fillcolor="#BBDEFB"]

            vr_context_sink [label=<<B>context-sink-compliance</B><BR/>Root context bloat<BR/>detection (&gt;5 includes)<BR/><I>timeout: 120s</I>>, shape=box, fillcolor="#BBDEFB"]

            vr_tool_place [label=<<B>tool-placement-analysis</B><BR/>Universal vs specialized<BR/>Inheritance-aware<BR/><I>timeout: 120s</I>>, shape=box, fillcolor="#BBDEFB"]
        }

        // ── Phase 2.6: Quality Classification ──
        subgraph cluster_quality {
            label="Phase 2.6: Quality Classification"
            style=rounded
            color="#78909C"
            bgcolor="#ECEFF1"

            vr_quality [label=<<B>quality-classification</B><BR/>Deterministic scoring<BR/>good | polish | needs_work | critical<BR/>→ requires_llm_analysis<BR/><I>timeout: 60s</I>>, shape=box, fillcolor="#BBDEFB"]
        }

        // ── Phase 3: Conditional LLM Analysis ──
        subgraph cluster_phase3 {
            label="Phase 3: Reporting"
            style=rounded
            color="#78909C"
            bgcolor="#ECEFF1"

            vr_init [label=<<B>initialize-optional-outputs</B><BR/>Set defaults for<BR/>conditional steps<BR/><I>timeout: 30s</I>>, shape=box, fillcolor="#E0E0E0"]

            vr_defaults [label="set-default-*\n(3 steps)", shape=box, fillcolor="#E0E0E0"]

            vr_llm_gate [label="requires_llm\nanalysis?", shape=diamond, fillcolor="#FFF9C4"]

            vr_quick [label=<<B>quick-approval</B><BR/>zen-architect<BR/>Quick PASS report<BR/><I>timeout: 120s</I>>, shape=box, fillcolor="#C8E6C9"]

            vr_composition [label=<<B>composition-analysis</B><BR/>zen-architect<BR/>How pieces fit together<BR/><I>timeout: 300s</I>>, shape=box, fillcolor="#C8E6C9"]

            vr_conventions [label=<<B>repo-conventions</B><BR/>zen-architect<BR/>Convention compliance<BR/><I>timeout: 300s</I>>, shape=box, fillcolor="#C8E6C9"]

            vr_final [label=<<B>synthesize-report</B><BR/>zen-architect<BR/>Final comprehensive report<BR/><I>timeout: 300s</I>>, shape=box, fillcolor="#A5D6A7"]

            vr_init -> vr_defaults
            vr_defaults -> vr_llm_gate
            vr_llm_gate -> vr_quick [label="false\n(clean repo)"]
            vr_llm_gate -> vr_composition [label="true\n(issues found)"]
            vr_llm_gate -> vr_conventions [label="true"]
            vr_composition -> vr_final
            vr_conventions -> vr_final
            vr_quick -> vr_final
        }

        // ── Cross-phase edges ──
        vr_env -> vr_pkg
        vr_build -> vr_disco
        vr_build_default -> vr_disco
        vr_disco -> vr_val_all

        // Phase 2 fan-out: all depend on validate-all-bundles
        vr_val_all -> vr_hygiene
        vr_val_all -> vr_standalone
        vr_val_all -> vr_experiments
        vr_val_all -> vr_context_sink
        vr_val_all -> vr_tool_place

        // Phase 2 fan-in: all feed quality classification
        vr_hygiene -> vr_quality
        vr_standalone -> vr_quality
        vr_experiments -> vr_quality
        vr_context_sink -> vr_quality
        vr_tool_place -> vr_quality
        vr_val_all -> vr_quality

        // Quality feeds Phase 3
        vr_quality -> vr_init
    }

    // ========================================================================
    // Legend
    // ========================================================================

    subgraph cluster_legend {
        label=<<B>Legend</B>>
        style=rounded
        color="#9E9E9E"
        bgcolor="#FAFAFA"
        fontsize=11

        node [shape=box, fontsize=9, height=0.3, width=1.8]

        leg_bash [label="bash step", fillcolor="#BBDEFB"]
        leg_agent [label="agent step (LLM)", fillcolor="#C8E6C9"]
        leg_foreach [label="foreach loop", shape=hexagon, fillcolor="#E1BEE7"]
        leg_gate [label="condition gate", shape=diamond, fillcolor="#FFF9C4"]
        leg_default [label="default/init step", fillcolor="#E0E0E0"]
        leg_final [label="final output step", fillcolor="#A5D6A7"]

        leg_bash -> leg_agent -> leg_foreach -> leg_gate -> leg_default -> leg_final [style=invis]
    }
}