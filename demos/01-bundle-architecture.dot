// Demo 1: amplifier-bundle-dot-graph — Bundle Architecture (Self-Documenting)
// Demonstrates: DOT as architecture documentation

digraph bundle_architecture {
    rankdir=TB
    compound=true
    fontname="Helvetica"
    fontsize=14
    label=<<B>amplifier-bundle-dot-graph — Bundle Architecture</B><BR/>
           <FONT POINT-SIZE="11">DOT/Graphviz Infrastructure for the Amplifier Ecosystem</FONT>>
    labelloc=t
    labeljust=c
    pad=0.6
    nodesep=0.5
    ranksep=0.7
    bgcolor="white"

    node [fontname="Helvetica", fontsize=10, style=filled]
    edge [fontname="Helvetica", fontsize=9, color="#555555"]

    // =========================================================================
    // Bundle manifest — entry point
    // =========================================================================

    bundle_md [label=<<B>bundle.md</B><BR/>
               <FONT POINT-SIZE="9">name: dot-graph  v0.1.0<BR/>
               General-purpose DOT/Graphviz infrastructure</FONT>>,
               shape=tab, fillcolor="#ECEFF1", color="#607D8B"]

    // =========================================================================
    // Behavior — composable wiring unit
    // =========================================================================

    subgraph cluster_behavior {
        label=<<B>behaviors/dot-graph.yaml</B>>
        style=rounded
        color="#78909C"
        penwidth=2
        bgcolor="#F5F5F5"

        behavior [label=<<B>dot-graph behavior</B><BR/>
                  <FONT POINT-SIZE="9">Wires: agents + tool module + context<BR/>
                  Any bundle can include this behavior</FONT>>,
                  shape=component, fillcolor="#ECEFF1", color="#607D8B"]
    }

    bundle_md -> behavior [label="  includes", style=dashed, color="#78909C"]

    // =========================================================================
    // Agents — delegatable sub-sessions
    // =========================================================================

    subgraph cluster_agents {
        label=<<B>agents/</B>>
        style=rounded
        color="#E65100"
        penwidth=2
        bgcolor="#FFF3E0"

        dot_author [label=<<B>dot-author</B><BR/>
                    <FONT POINT-SIZE="9">Expert DOT/Graphviz author<BR/>
                    Create · Edit · Refine · Explain<BR/>
                    model_role: coding</FONT>>,
                    shape=box, style="rounded,filled",
                    fillcolor="#FFE0B2", color="#E65100"]

        diagram_reviewer [label=<<B>diagram-reviewer</B><BR/>
                          <FONT POINT-SIZE="9">Objective quality reviewer<BR/>
                          5-level checklist · PASS/WARN/FAIL<BR/>
                          model_role: critique</FONT>>,
                          shape=box, style="rounded,filled",
                          fillcolor="#FFCCBC", color="#BF360C"]
    }

    behavior -> dot_author      [label="includes", style=dashed, color="#E65100"]
    behavior -> diagram_reviewer [label="includes", style=dashed, color="#BF360C"]

    // =========================================================================
    // Tier 2: Tool module — validation & rendering
    // =========================================================================

    subgraph cluster_tier2 {
        label=<<B>Tier 2 — Validation &amp; Rendering</B><BR/>
               <FONT POINT-SIZE="9">modules/tool-dot-graph  (Python package)</FONT>>
        style=rounded
        color="#2E7D32"
        penwidth=2
        bgcolor="#E8F5E9"

        tool_module [label=<<B>tool-dot-graph</B><BR/>
                     <FONT POINT-SIZE="9">pyproject.toml · pip installable<BR/>
                     Graphviz wrapper + NetworkX</FONT>>,
                     shape=component, fillcolor="#DCEDC8", color="#558B2F"]

        dot_validate [label=<<B>dot_validate</B><BR/><FONT POINT-SIZE="9">Syntax checking</FONT>>,
                      shape=ellipse, fillcolor="#C8E6C9", color="#2E7D32"]
        dot_render   [label=<<B>dot_render</B><BR/><FONT POINT-SIZE="9">PNG/SVG/PDF output</FONT>>,
                      shape=ellipse, fillcolor="#C8E6C9", color="#2E7D32"]
        dot_setup    [label=<<B>dot_setup</B><BR/><FONT POINT-SIZE="9">Graphviz install check</FONT>>,
                      shape=ellipse, fillcolor="#C8E6C9", color="#2E7D32"]
        dot_analyze  [label=<<B>dot_analyze</B><BR/>
                      <FONT POINT-SIZE="9">NetworkX-backed analysis<BR/>
                      paths · centrality · cycles</FONT>>,
                      shape=ellipse, fillcolor="#A5D6A7", color="#1B5E20"]

        tool_module -> dot_validate [dir=none, style=dashed, color="#81C784"]
        tool_module -> dot_render   [dir=none, style=dashed, color="#81C784"]
        tool_module -> dot_setup    [dir=none, style=dashed, color="#81C784"]
        tool_module -> dot_analyze  [dir=none, style=dashed, color="#66BB6A"]
    }

    behavior -> tool_module [label="tools:", style=dashed, color="#2E7D32"]

    // =========================================================================
    // Tier 1: Knowledge layer — zero dependencies
    // =========================================================================

    subgraph cluster_tier1 {
        label=<<B>Tier 1 — Knowledge Layer</B><BR/>
               <FONT POINT-SIZE="9">Zero-dependency: works without Graphviz installed</FONT>>
        style=rounded
        color="#1565C0"
        penwidth=2
        bgcolor="#E3F2FD"

        subgraph cluster_skills {
            label=<<B>skills/</B>>
            style=rounded
            color="#1976D2"
            bgcolor="#BBDEFB"

            sk_syntax   [label="dot-syntax",           shape=tab, fillcolor="#E3F2FD", color="#1976D2"]
            sk_patterns [label="dot-patterns",         shape=tab, fillcolor="#E3F2FD", color="#1976D2"]
            sk_analysis [label="dot-as-analysis",      shape=tab, fillcolor="#E3F2FD", color="#1976D2"]
            sk_quality  [label="dot-quality",          shape=tab, fillcolor="#E3F2FD", color="#1976D2"]
            sk_intel    [label="dot-graph-intelligence", shape=tab, fillcolor="#E3F2FD", color="#1976D2"]
        }

        subgraph cluster_docs {
            label=<<B>docs/</B>>
            style=rounded
            color="#0288D1"
            bgcolor="#B3E5FC"

            doc_syntax   [label="DOT-SYNTAX-REFERENCE.md",  shape=note, fillcolor="#E1F5FE", color="#0277BD"]
            doc_patterns [label="DOT-PATTERNS.md",          shape=note, fillcolor="#E1F5FE", color="#0277BD"]
            doc_quality  [label="DOT-QUALITY-STANDARDS.md", shape=note, fillcolor="#E1F5FE", color="#0277BD"]
            doc_setup    [label="GRAPHVIZ-SETUP.md",        shape=note, fillcolor="#E1F5FE", color="#0277BD"]
            doc_analysis [label="GRAPH-ANALYSIS-GUIDE.md",  shape=note, fillcolor="#E1F5FE", color="#0277BD"]
        }

        subgraph cluster_context {
            label=<<B>context/</B>>
            style=rounded
            color="#0097A7"
            bgcolor="#B2EBF2"

            ctx_awareness    [label="dot-awareness.md",    shape=note, fillcolor="#E0F7FA", color="#00838F"]
            ctx_instructions [label="dot-instructions.md", shape=note, fillcolor="#E0F7FA", color="#00838F"]
        }
    }

    behavior -> ctx_awareness [label="context: awareness", color="#0097A7", style=dashed]

    // Skills referenced by agents
    dot_author -> sk_syntax    [style=dashed, color="#90CAF9", label="  loads on demand"]
    dot_author -> sk_patterns  [style=dashed, color="#90CAF9"]
    dot_author -> doc_syntax   [style=dashed, color="#90CAF9"]
    dot_author -> doc_patterns [style=dashed, color="#90CAF9"]
    diagram_reviewer -> sk_quality  [style=dashed, color="#EF9A9A", label="  loads on demand"]
    diagram_reviewer -> doc_quality [style=dashed, color="#EF9A9A"]

    // Additional on-demand skill/doc references
    dot_author -> sk_analysis [style=dashed, color="#90CAF9"]
    dot_author -> sk_intel    [style=dashed, color="#90CAF9"]
    dot_author -> doc_analysis [style=dashed, color="#90CAF9"]
    diagram_reviewer -> doc_setup [style=dashed, color="#EF9A9A"]
    behavior -> ctx_instructions  [label="context: instructions", color="#0097A7", style=dashed]

    // =========================================================================
    // Legend
    // =========================================================================

    subgraph cluster_legend {
        label=<<B>Legend</B>>
        style=rounded
        color="#9E9E9E"
        bgcolor="#FAFAFA"
        fontsize=11
        node [fontsize=9, height=0.3]

        leg_bundle  [label="Bundle manifest",      shape=tab,       fillcolor="#ECEFF1", width=1.7]
        leg_comp    [label="Behavior / wiring",    shape=component, fillcolor="#E0E0E0", width=1.7]
        leg_agent   [label="Agent (delegatable)",  shape=box, style="rounded,filled", fillcolor="#FFE0B2", width=1.7]
        leg_tool    [label="Tool function",        shape=ellipse,   fillcolor="#C8E6C9", width=1.7]
        leg_module  [label="Python package",       shape=component, fillcolor="#DCEDC8", width=1.7]
        leg_skill   [label="Skill / context file", shape=tab,       fillcolor="#E3F2FD", width=1.7]
        leg_doc     [label="Reference document",   shape=note,      fillcolor="#E1F5FE", width=1.7]

        leg_bundle -> leg_comp -> leg_agent -> leg_tool -> leg_module -> leg_skill -> leg_doc [style=invis]

        // Color-tier key
        leg_col1 [label="Blue   — Tier 1: Knowledge", shape=plaintext, fontcolor="#1565C0", fontsize=9, width=2.0]
        leg_col2 [label="Green  — Tier 2: Tools",     shape=plaintext, fontcolor="#2E7D32", fontsize=9, width=2.0]
        leg_col3 [label="Orange — Agents",            shape=plaintext, fontcolor="#E65100", fontsize=9, width=2.0]
        leg_col4 [label="Grey   — Behavior / config", shape=plaintext, fontcolor="#607D8B", fontsize=9, width=2.0]
        leg_col1 -> leg_col2 -> leg_col3 -> leg_col4 [style=invis]
        leg_doc  -> leg_col1 [style=invis]
    }
}
